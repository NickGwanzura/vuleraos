generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ TENANCY ============

model Tenant {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  businessType        BusinessType @default(SOLE_TRADER)
  bpNumber            String?  // VAT/Business Partner number
  registrationNumber  String?
  defaultCurrency     String   @default("USD")
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users              User[]
  currencies         Currency[]
  exchangeRates      ExchangeRate[]
  businessPartners   BusinessPartner[]
  categories         ItemCategory[]
  items              Item[]
  stockTransactions  StockTransaction[]
  salesInvoices      SalesInvoice[]
  purchaseOrders     PurchaseOrder[]
  payments           Payment[]
  employees          Employee[]
  payrollRuns        PayrollRun[]
  fiscalDevices      FiscalDevice[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  documentTemplates  DocumentTemplate[]

  @@map("tenants")
}

enum BusinessType {
  SOLE_TRADER
  PBC
  PRIVATE_LIMITED
  PUBLIC_LIMITED
  PARTNERSHIP

  @@map("business_type")
}

// ============ AUTH & USERS ============

model User {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid
  email               String   @unique
  name                String
  passwordHash        String?
  role                UserRole @default(STAFF)
  isActive            Boolean  @default(true)
  onboardingCompleted Boolean  @default(false)
  image               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  accounts        Account[]
  sessions        Session[]
  exchangeRates   ExchangeRate[]
  createdInvoices SalesInvoice[]        @relation("InvoiceCreatedBy")
  createdPOs      PurchaseOrder[]       @relation("POCreatedBy")
  approvedPOs     PurchaseOrder[]       @relation("POApprovedBy")
  processedPayrolls PayrollRun[] @relation("PayrollProcessedBy")
  stockTransactions StockTransaction[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  createdPayments Payment[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  CASHIER
  STAFF

  @@map("user_role")
}

// Auth.js models
model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============ CURRENCY ============

model Currency {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @db.Uuid
  code          String  // USD, ZWG
  symbol        String  // $, ZiG
  name          String
  isBase        Boolean @default(false)
  decimalPlaces Int     @default(2)
  isActive      Boolean @default(true)

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exchangeRates ExchangeRate[]  @relation("CurrencyFrom")
  exchangeRatesTo ExchangeRate[] @relation("CurrencyTo")
  businessPartners BusinessPartner[]
  items            Item[]
  stockTransactions StockTransaction[]
  invoices         SalesInvoice[]
  invoiceItems     InvoiceItem[]
  purchaseOrders   PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  payments         Payment[]
  employees        Employee[]
  payrollRuns      PayrollRun[]
  payrollItems     PayrollItem[]

  @@unique([tenantId, code])
  @@map("currencies")
}

model ExchangeRate {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  fromCurrencyId    String   @db.Uuid
  toCurrencyId      String   @db.Uuid
  rate              Decimal  @db.Decimal(18, 6)
  parallelMarketRate Decimal? @db.Decimal(18, 6)
  effectiveDate     DateTime
  isManualOverride  Boolean  @default(false)
  notes             String?
  createdByUserId   String   @db.Uuid
  createdAt         DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromCurrency Currency @relation("CurrencyFrom", fields: [fromCurrencyId], references: [id])
  toCurrency   Currency @relation("CurrencyTo", fields: [toCurrencyId], references: [id])
  createdBy    User     @relation(fields: [createdByUserId], references: [id])
  invoices     SalesInvoice[]
  invoiceItems InvoiceItem[]
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  stockTransactions StockTransaction[]
  payments     Payment[]

  @@index([tenantId, fromCurrencyId, toCurrencyId, effectiveDate])
  @@map("exchange_rates")
}

// ============ BUSINESS PARTNERS ============

model BusinessPartner {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @db.Uuid
  partnerType PartnerType
  name        String
  bpNumber    String?            // VAT Registration / BP Number
  tinNumber   String?            // Taxpayer Identification Number
  contactPerson String?
  email       String?
  phone       String?
  address     String?
  city        String?
  creditLimit Decimal?           @db.Decimal(18, 2)
  currencyId  String?            @db.Uuid
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency      Currency?      @relation(fields: [currencyId], references: [id])
  salesInvoices SalesInvoice[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, partnerType])
  @@map("business_partners")
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  BOTH

  @@map("partner_type")
}

// ============ INVENTORY ============

model ItemCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  parentId  String?  @db.Uuid
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   ItemCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryHierarchy")
  items    Item[]

  @@unique([tenantId, name])
  @@map("item_categories")
}

model Item {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid
  name            String
  sku             String
  description     String?
  categoryId      String?        @db.Uuid
  unitOfMeasure   String         @default("each")
  defaultPrice    Decimal?       @db.Decimal(18, 2)
  costPrice       Decimal?       @db.Decimal(18, 2)
  currencyId      String?        @db.Uuid
  currentStock    Decimal        @default(0) @db.Decimal(18, 2)
  minimumStock    Decimal?       @db.Decimal(18, 2)
  valuationMethod ValuationMethod @default(FIFO)
  isActive        Boolean        @default(true)
  barcode         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant             Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category           ItemCategory?                @relation(fields: [categoryId], references: [id])
  currency           Currency?                    @relation(fields: [currencyId], references: [id])
  stockTransactions  StockTransaction[]
  invoiceItems       InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
  @@map("items")
}

enum ValuationMethod {
  FIFO
  WEIGHTED_AVERAGE

  @@map("valuation_method")
}

model StockTransaction {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @db.Uuid
  itemId        String               @db.Uuid
  type          StockTransactionType
  quantity      Decimal              @db.Decimal(18, 2)
  unitCost      Decimal?             @db.Decimal(18, 2)
  currencyId    String?              @db.Uuid
  exchangeRateId String?             @db.Uuid
  referenceType String?              // invoice, purchase_order, adjustment
  referenceId   String?              // UUID of the reference document
  notes         String?
  createdById   String               @db.Uuid
  createdAt     DateTime             @default(now())

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item         Item           @relation(fields: [itemId], references: [id])
  currency     Currency?      @relation(fields: [currencyId], references: [id])
  exchangeRate ExchangeRate?  @relation(fields: [exchangeRateId], references: [id])
  createdBy    User           @relation(fields: [createdById], references: [id])

  @@index([tenantId, itemId, createdAt])
  @@map("stock_transactions")
}

enum StockTransactionType {
  IN
  OUT
  ADJUSTMENT

  @@map("stock_transaction_type")
}

// ============ SALES & INVOICING ============

model SalesInvoice {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  invoiceNumber   String
  customerId      String        @db.Uuid
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  status          InvoiceStatus @default(DRAFT)
  currencyId      String        @db.Uuid
  exchangeRateId  String?       @db.Uuid
  subtotal        Decimal       @db.Decimal(18, 2)
  vatAmount       Decimal       @default(0) @db.Decimal(18, 2)
  vatRate         Decimal       @default(0) @db.Decimal(5, 2)
  total           Decimal       @db.Decimal(18, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(18, 2)
  balanceDue      Decimal       @db.Decimal(18, 2)
  notes           String?
  fiscalDeviceId  String?       @db.Uuid
  isFiscalised    Boolean       @default(false)
  fiscalReceiptNumber String?
  transactionRef  String?       // EcoCash/OneMoney/RTGS reference
  paymentMethod   PaymentMethod?
  createdById     String        @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       BusinessPartner @relation(fields: [customerId], references: [id])
  currency       Currency        @relation(fields: [currencyId], references: [id])
  exchangeRate   ExchangeRate?   @relation(fields: [exchangeRateId], references: [id])
  fiscalDevice   FiscalDevice?   @relation(fields: [fiscalDeviceId], references: [id])
  createdBy      User            @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items          InvoiceItem[]
  payments       Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status, issueDate])
  @@map("sales_invoices")
}

enum InvoiceStatus {
  DRAFT
  FISCAL
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED

  @@map("invoice_status")
}

model InvoiceItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @db.Uuid
  itemId      String? @db.Uuid
  description String
  quantity    Decimal @db.Decimal(18, 2)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @db.Decimal(18, 2)
  currencyId  String  @db.Uuid
  exchangeRateId String? @db.Uuid

  invoice      SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item         Item?        @relation(fields: [itemId], references: [id])
  currency     Currency     @relation(fields: [currencyId], references: [id])
  exchangeRate ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  @@map("invoice_items")
}

// ============ PROCUREMENT ============

model PurchaseOrder {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @db.Uuid
  poNumber        String
  supplierId      String       @db.Uuid
  orderDate       DateTime     @default(now())
  expectedDate    DateTime?
  status          POStatus     @default(DRAFT)
  currencyId      String       @db.Uuid
  exchangeRateId  String?      @db.Uuid
  subtotal        Decimal      @db.Decimal(18, 2)
  vatAmount       Decimal      @default(0) @db.Decimal(18, 2)
  total           Decimal      @db.Decimal(18, 2)
  notes           String?
  createdById     String       @db.Uuid
  approvedById    String?      @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       BusinessPartner @relation(fields: [supplierId], references: [id])
  currency       Currency        @relation(fields: [currencyId], references: [id])
  exchangeRate   ExchangeRate?   @relation(fields: [exchangeRateId], references: [id])
  createdBy      User            @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedBy     User?           @relation("POApprovedBy", fields: [approvedById], references: [id])
  items          PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@map("purchase_orders")
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED

  @@map("po_status")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @db.Uuid
  itemId          String? @db.Uuid
  description     String
  quantity        Decimal @db.Decimal(18, 2)
  quantityReceived Decimal @default(0) @db.Decimal(18, 2)
  unitPrice       Decimal @db.Decimal(18, 2)
  lineTotal       Decimal @db.Decimal(18, 2)
  currencyId      String  @db.Uuid
  exchangeRateId  String? @db.Uuid

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item?         @relation(fields: [itemId], references: [id])
  currency      Currency      @relation(fields: [currencyId], references: [id])
  exchangeRate  ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  @@map("purchase_order_items")
}

// ============ PAYMENTS ============

enum PaymentMethod {
  ECOCASH
  ONEMONEY
  RTGS
  BANK_TRANSFER
  CASH
  OTHER

  @@map("payment_method")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  invoiceId       String?       @db.Uuid
  amount          Decimal       @db.Decimal(18, 2)
  currencyId      String        @db.Uuid
  exchangeRateId  String?       @db.Uuid
  paymentMethod   PaymentMethod
  referenceNumber String?       // Transaction reference from payment provider
  bankName        String?
  matchedInvoiceId String?      @db.Uuid // For manual RTGS matching
  isReconciled    Boolean       @default(false)
  receivedAt      DateTime      @default(now())
  notes           String?
  createdById     String        @db.Uuid
  createdAt       DateTime      @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice      SalesInvoice? @relation(fields: [invoiceId], references: [id])
  currency     Currency      @relation(fields: [currencyId], references: [id])
  exchangeRate ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])

  @@index([tenantId, receivedAt])
  @@map("payments")
}

// ============ HR & PAYROLL ============

model Employee {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  employeeCode  String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  department    String?
  position      String?
  basicSalary   Decimal? @db.Decimal(18, 2)
  currencyId    String?  @db.Uuid
  bankName      String?
  bankAccount   String?
  taxIdNumber   String?  // PAYE number
  nssaNumber    String?
  startDate     DateTime @default(now())
  endDate       DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency    Currency?     @relation(fields: [currencyId], references: [id])
  payrollItems PayrollItem[]

  @@unique([tenantId, employeeCode])
  @@map("employees")
}

model PayrollRun {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  periodStart DateTime
  periodEnd   DateTime
  status      PayrollStatus @default(DRAFT)
  totalGross  Decimal       @default(0) @db.Decimal(18, 2)
  totalDeductions Decimal   @default(0) @db.Decimal(18, 2)
  totalNet    Decimal       @default(0) @db.Decimal(18, 2)
  totalPaye   Decimal       @default(0) @db.Decimal(18, 2)
  totalNssa   Decimal       @default(0) @db.Decimal(18, 2)
  totalNec    Decimal       @default(0) @db.Decimal(18, 2)
  totalAid    Decimal       @default(0) @db.Decimal(18, 2)
  currencyId  String        @db.Uuid
  processedById String      @db.Uuid
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency     Currency      @relation(fields: [currencyId], references: [id])
  processedBy  User          @relation("PayrollProcessedBy", fields: [processedById], references: [id])
  items        PayrollItem[]

  @@map("payroll_runs")
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED

  @@map("payroll_status")
}

model PayrollItem {
  id            String  @id @default(uuid()) @db.Uuid
  payrollRunId  String  @db.Uuid
  employeeId    String  @db.Uuid
  grossPay      Decimal @db.Decimal(18, 2)
  payeTax       Decimal @default(0) @db.Decimal(18, 2)
  nssaDeduction Decimal @default(0) @db.Decimal(18, 2)
  necDeduction  Decimal @default(0) @db.Decimal(18, 2)
  aidDeduction  Decimal @default(0) @db.Decimal(18, 2)
  otherDeductions Decimal @default(0) @db.Decimal(18, 2)
  totalDeductions Decimal @default(0) @db.Decimal(18, 2)
  netPay        Decimal @db.Decimal(18, 2)
  currencyId    String  @db.Uuid

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])
  currency   Currency   @relation(fields: [currencyId], references: [id])

  @@map("payroll_items")
}

// ============ ZIMRA COMPLIANCE ============

model FiscalDevice {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  deviceId          String
  serialNumber      String
  model             String
  status            String   @default("ACTIVE")
  lastCommunication DateTime?
  certificate       String?  // Device certificate for FDMS
  createdAt         DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesInvoices  SalesInvoice[]

  @@unique([tenantId, deviceId])
  @@map("fiscal_devices")
}

// ============ AUDIT & NOTIFICATIONS ============

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  userId     String   @db.Uuid
  action     String   // create, update, delete
  entityType String   // sales_invoice, item, etc.
  entityId   String   @db.Uuid
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String?
  type      String   // approval, alert, mention, system
  link      String?  // URL to the relevant record
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, isRead])
  @@map("notifications")
}

model DocumentTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  type      String   // invoice, purchase_order, receipt, payslip
  content   Json     // Template configuration (letterhead, layout, fields)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@map("document_templates")
}
